# Required
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# Collateral token used by Vault (supports decimals <= 18; USDC 6-decimals is supported)
USDC=0xYOUR_USDC

# Optional infra overrides (defaults to Unichain Sepolia constants in scripts)
POOL_MANAGER=0x00b036b58a818b1bc34d502d3fe730db729e62ac
POSITION_MANAGER=0xf969aee60879c54baaed9f3ed26147db216fd664
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# Recommended router for this repo (supports IUniswapV4Router04 + msgSender)
SWAP_ROUTER=0x9cD2b0a732dd5e023a5539921e0FD1c30E198Dba
# If using router that doesn't expose msgSender(), set false
VERIFY_SWAP_ROUTER_AS_MSG_SENDER=true

# Optional: external oracle. If empty/omitted, deploy script creates ManualPriceOracle
# PRICE_ORACLE=0x...
INITIAL_ORACLE_PRICE_X18=3000000000000000000000

# LiquidityController params
LC_DEADBAND_BPS=10
LC_MAX_REPRICE_BPS=30
LC_MAX_AMOUNT_IN=5000000000000000000
LC_MIN_VAMM_LIQUIDITY=1000000000000000000000

# Virtual token inventories seeded by deploy script
CH_VETH_INVENTORY=1000000000000000000000000
CH_VUSDC_INVENTORY=10000000000000000000000000000
LC_VETH_INVENTORY=50000000000000000000000
LC_VUSDC_INVENTORY=150000000000000000000000000

# Insurance fund
INSURANCE_BENEFICIARY=0xYOUR_BENEFICIARY
INSURANCE_DISTRIBUTION_THRESHOLD=200000000000000000000000

# Optional: liquidation tracker callback (e.g., LiquidationDestinationCallback).
# If set, deploy script wires ClearingHouse.setLiquidationTracker(...)
LIQUIDATION_TRACKER=0x0000000000000000000000000000000000000000

# Init/bootstrap script
PERP_HOOK=0xDEPLOYED_HOOK
VETH=0xDEPLOYED_VETH
VUSDC=0xDEPLOYED_VUSDC
LP_RECIPIENT=0xYOUR_ADDRESS
VAMM_INIT_PRICE_X18=3000000000000000000000
SPOT_INIT_PRICE_X18=3000000000000000000000
VAMM_BOOTSTRAP_LIQUIDITY=1000000000000000000000
SPOT_BOOTSTRAP_LIQUIDITY=0
# Optional spot bootstrap by token amounts (raw units), script computes liquidity from these.
# Do not set together with SPOT_BOOTSTRAP_LIQUIDITY > 0.
# SPOT_BOOTSTRAP_ETH_AMOUNT=100000000000000000   # 0.1 ETH
# SPOT_BOOTSTRAP_USDC_AMOUNT=230000000           # 230 USDC (6 decimals)

# Smoke test script
VAULT=0xDEPLOYED_VAULT
CLEARING_HOUSE=0xDEPLOYED_CLEARING_HOUSE
# token raw units (for USDC-6: 1000000000 = 1000 USDC)
SMOKE_DEPOSIT_AMOUNT=1000000000
SMOKE_OPEN_AMOUNT=1000000000000000000

# Manual oracle update script
NEW_ORACLE_PRICE_X18=2800000000000000000000
